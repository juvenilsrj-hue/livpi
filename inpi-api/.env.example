# LIV CRM — credenciais (copie para ".env" e preencha; NÃO comite o .env preenchido)

# Supabase (banco de produção do Kanban). Crie um projeto em https://supabase.com,
# rode o supabase-schema.sql no SQL Editor e pegue os valores em
# Project Settings > API. A service_role é SECRETA — só no backend.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=cole_aqui_a_service_role_key

# Enquanto estes não estiverem preenchidos, o CRM roda no store local (_cache/crm.json).

# --- Fase C (e-mail) — definir quando escolhermos o provedor/domínio ---
# RESEND_API_KEY=
# EMAIL_FROM=prospeccao@seudominio.com.br
